{
    // 使用 IntelliSense 了解相关属性。 
    // 悬停以查看现有属性的描述。
    // 欲了解更多信息，请访问: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "(gdb) 启动",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/Examples/RGB-D-Inertial/rgbd_inertial",
            // "args": ["${workspaceFolder}/Vocabulary/ORBvoc.txt", "${workspaceFolder}/Examples/RGB-D/RealSense_D435i.yaml", "${workspaceFolder}/datasets/Real/D435I/2026-04-24-08-20-35", "${workspaceFolder}/datasets/Real/D435I/2026-04-24-08-20-35/associates.txt"],
            "args": ["${workspaceFolder}/Vocabulary/ORBvoc.txt", "${workspaceFolder}/Examples/RGB-D-Inertial/RealSense_D435i.yaml", "${workspaceFolder}/datasets/Real/D435I/2026-04-24-08-20-35", "${workspaceFolder}/datasets/Real/D435I/2026-04-24-08-20-35/associates.txt", "${workspaceFolder}/datasets/Real/D435I/2026-04-24-08-20-35/camera_imu.txt"],
            "stopAtEntry": false,
            "cwd": "${fileDirname}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "description": "为 gdb 启用整齐打印",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                },
                {
                    "description": "将反汇编风格设置为 Intel",
                    "text": "-gdb-set disassembly-flavor intel",
                    "ignoreFailures": true
                }
            ],
            "miDebuggerPath": "/usr/bin/gdb"
        }

    ]
}